<style type=3D"text/css">/*body tag will be style if changed by an ESP*/
    html,  body, p, li, blockquote {width: 100% !important;-webkit-text-siz=
e-adjust:none; margin:0;padding:0;-ms-text-size-adjust:100%;}
    /* Stops email clients resizing small text. */
    * {-ms-text-size-adjust: 100%;-webkit-text-size-adjust: 100%;}
    /*text on yahoo mail*/
    .yshortcuts { color: #707070;}
    /*link in yahoo mail should be same as global links*/
    .yshortcuts a span { color: #CF1E48;}  =20
    .yshortcuts a {border-bottom: none !important;}  =20
    /*global links*/
 =20
    /*Emails wrapped in this class for hotmail and Outlook.com*/
    .ExternalClass{width: 100% !important;-webkit-text-size-adjust:none; ma=
rgin:0;padding:0;-ms-text-size-adjust:100%;}
    /* Fixes webkit padding issue. Fix for Yahoo mail table alignment bug. =
Applies table-layout to the first 2 tables then removes for anything nested=
 deeper. */
    table {border-spacing: 0 !important;  table-layout: fixed;margin: 0 aut=
o !important;}
    table table table {table-layout: auto;}
    /* Uses a better rendering method when resizing images in IE. */
    img {-ms-interpolation-mode: bicubic;}

    /*class to display table structure visually in DW*/
    .container{width:700px;}
    /*Make width of emails wider in Samsung*/
    #MessageViewBody, #MessageWebViewDiv{width: 100% !important;}
    /* Another work-around for iOS meddling in triggered links. */
    a[x-apple-data-detectors] {color: inherit !important;}=20
    /* Global decleration for tel and sms links */
    a[href^=3D"tel"], a[href^=3D"sms"] {text-decoration: none;color: black;=
 /* or whatever your want */pointer-events: none;cursor: default;}
    .mobile_link a[href^=3D"tel"], .mobile_link a[href^=3D"sms"] =20
   =20
    /* Smartphones */
    @media only screen and (max-width:480px) {
        /*Make body margin 0 - targetting Android*/
        body{margin:0 !important;}
        /*Make everything with class full width*/
        .hundred, .container{width:100% !important;max-width:100% !importan=
t;}
        /*hide in mobile*/
        .desktop { display:none !important;}
        /*images inside banner class will resize proportionatly*/
        .banner img{width:100% !important; height:auto !important}
        /*show mobile contents in mobile if hidden in desktop*/
        .mobile{display:block !important; width:100% !important; max-height=
:inherit !important; overflow:visible !important;}
        /*remove padding completely*/
        .zero{padding:0px !important;}
        /*columns to rows*/
        .Colms th{display:inline-block; width:100%;}
         tr.buttons td a {padding: 5px !important;}
=09=09tr td:nth-child(21) a {padding: 5px 0px !important;}
    }
    /*not smart phones*/
    @media only screen and (max-width:701px){
        /*make container size 700px wide
        .container{width:700px;}*/
    }
=09
=09table td {border-collapse: collapse; }
=09
=09div#footer{
font-size:10px !important;
}  div#footer{
font-size:10px !important;
}  a {
    color: #001272!important;
}

.ii a[href] {
color: #001272 !important;
}
</style>
<style type=3D"text/css">/** Hotmail header color reset: Hotmail replaces y=
our header color styles with a green color on H2, H3, H4, H5, and H6 tags. =
In this example, the color is reset to black for a non-linked header, blue =
for a linked header, red for an active header (limited support), and purple=
 for a visited header (limited support).  Replace with your choice of color=
. The !important is really what is overriding Hotmail's styling. Hotmail al=
so sets the H1 and H2 tags to the same size.

=20
   =20
    @media only screen and (min-device-width: 768px) and (max-device-width:=
 1024px) {
        /* targetting tablets, smaller screens, etc */
    }
    @media only screen and (-webkit-min-device-pixel-ratio: 2) {
        /* Put your iPhone 4g styles in here */
    }
    /* Following Android targeting from:
    http://developer.android.com/guide/webapps/targeting.html
    http://pugetworks.com/2011/04/css-media-queries-for-targeting-different=
-mobile-devices/  */
    @media only screen and (-webkit-device-pixel-ratio:.75){
        /* Put CSS for low density (ldpi) Android layouts in here */
    }
    @media only screen and (-webkit-device-pixel-ratio:1){
        /* Put CSS for medium density (mdpi) Android layouts in here */
    }
    @media only screen and (-webkit-device-pixel-ratio:1.5){
        /* Put CSS for high density (hdpi) Android layouts in here */
    }
</style>
<style type=3D"text/css">/* Desktop default */
     .selectors {
    width: 100px !important;
    min-height: 80px !important;
   =20
    color: #f2f2f2 !important;
    text-align: center !important;
   =20
    font-weight: bold !important;
    border-radius: 8px !important;
    text-decoration: none !important;
    box-sizing: border-box !important;
    vertical-align: middle !important;
  }

  .selectors a {
  =20
    align-items: center !important;
    justify-content: center !important;
    height: 100% !important;
    line-height: 1.2 !important;
    padding: 10px !important;
  }

  @media only screen and (max-width: 480px) {


   .selectors {
      width: 45% !important;
      min-height: 80px !important;
    }
=09
=09
  }
</style>
